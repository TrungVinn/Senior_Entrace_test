# =============================================================================
# Stream Pipeline — Environment Configuration
# =============================================================================
# Copy to .env and replace {{...}} placeholders with real values.

# --- Kafka (Aiven managed broker) ---
# Format: hostname:port (from Aiven console → Overview → Connection information)
KAFKA_BOOTSTRAP_SERVERS=kafka-xxxxx-yourname-xxxx.i.aivencloud.com:XXXXX
KAFKA_TOPIC=binance_market_data
KAFKA_CONSUMER_GROUP=market_processor
KAFKA_AUTO_OFFSET_RESET=earliest
# Cert files go in jobs/ folder (never commit them).
# Docker uses /app/certs/* paths from docker-compose. For local Python runs,
# point these to your local files, e.g. ../ca.pem when running from jobs/src.
KAFKA_SSL_CA=/app/certs/ca.pem
KAFKA_SSL_CERT=/app/certs/service.cert
KAFKA_SSL_KEY=/app/certs/service.key

# --- ClickHouse Cloud ---
CLICKHOUSE_HOST={{CLICKHOUSE_HOST}}
CLICKHOUSE_PORT=8443            # HTTPS port for Python clickhouse-connect (processor, AI runner)
CLICKHOUSE_NATIVE_PORT=9440     # Native TCP port for Go backend clickhouse-go driver
CLICKHOUSE_USER={{CLICKHOUSE_USER}}
CLICKHOUSE_PASSWORD={{CLICKHOUSE_PASSWORD}}
CLICKHOUSE_DATABASE=default
CLICKHOUSE_SECURE=true

# --- Binance WebSocket ---
BINANCE_SYMBOLS=btcusdt,ethusdt,bnbusdt,solusdt,xrpusdt
BINANCE_INTERVAL=1m

# --- Optional frontend LLM panel ---
# Used only by the Intelligence tab's browser-side Gemini panel.
# Leave empty to run the dashboard without LLM calls.
VITE_GEMINI_API_KEY=

# --- Stream Processor ---
STREAM_BATCH_SIZE=500
STREAM_POLL_TIMEOUT_S=5.0
STREAM_PROCESSING_INTERVAL=10 seconds
SPARK_CHECKPOINT_DIR=/dbfs/checkpoints/stream_processor

# --- PostgreSQL (existing template) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trading_db

# --- General ---
LOG_LEVEL=INFO
