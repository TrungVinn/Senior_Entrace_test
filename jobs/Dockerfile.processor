FROM python:3.12-slim

WORKDIR /app

# Install processor dependencies (no Spark needed)
RUN pip install --no-cache-dir \
    "redis[hiredis]>=5.0.0" \
    "clickhouse-connect>=0.7.0" \
    "pandas>=2.2.0" \
    "numpy>=1.26.0" \
    "python-dotenv>=1.0.1"

# Copy source
COPY src/config/ config/
COPY src/utils/ utils/
COPY src/common/ common/
COPY src/stream/ stream/

# Non-root user
RUN useradd --create-home appuser
USER appuser

CMD ["python", "-m", "stream.processor_standalone"]
