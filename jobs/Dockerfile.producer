FROM python:3.12-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    "aiokafka>=0.10.0" \
    "websockets>=12.0" \
    "python-dotenv>=1.0.1"

COPY src/config/ config/
COPY src/utils/logger.py utils/logger.py
COPY src/utils/__init__.py utils/__init__.py
COPY src/stream/ stream/

RUN useradd --create-home appuser
USER appuser

CMD ["python", "-m", "stream.producer"]
